# ⚠️ DEPRECATED: file này chỉ dành cho proxy Node cũ (scripts/gemini_proxy.js).
# Luồng chính hiện nay: backend .NET giữ Gemini key qua user-secrets hoặc env var:
#   cd backend/src/CaloriesTracking.Api
#   dotnet user-secrets set "Gemini:ApiKey" "your_key"
# (production: đặt biến môi trường GEMINI__APIKEY)
GEMINI_API_KEY=your_gemini_api_key_here
